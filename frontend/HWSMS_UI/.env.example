# ===============================================
# HWSMS Frontend - Environment Variables Template
# ===============================================
# Copy this file to .env.development for development
# Copy this file to .env.production for production
# Never commit .env files to version control

# Backend API Base URL
# Development: http://localhost:5162
# Production (Railway/Azure): https://your-backend-host (without trailing slash)
VITE_API_BASE_URL=http://localhost:5162

# Optional: Enable debug logging
VITE_DEBUG=false
